# ===== App =====
APP_NAME=Task Manager API
DEBUG=True

# ===== Database =====
# Local development with SQLite (no setup required):
DATABASE_URL=sqlite:///./taskmanager.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/taskmanager

# ===== Security =====
# In production, generate with: openssl rand -hex 32
# The app will refuse to start with the default value when DEBUG=False.
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== CORS =====
# Comma-separated list of origins allowed to call the API.
# In production set this to your frontend URL, e.g.:
# CORS_ORIGINS=https://taskmanager.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000